# API network settings
HOST=0.0.0.0
PORT=8080

# Optional API controls
# API_KEY=
RATE_LIMIT_PER_MIN=120
INDEX_DB_PATH=data/chainindex.db

# Optional global RPC override
# CHAINMERGE_RPC_URL=

# Optional chain-specific RPC overrides
CHAINMERGE_RPC_URL_ETHEREUM=https://ethereum-rpc.publicnode.com
CHAINMERGE_RPC_URL_SOLANA=https://api.mainnet-beta.solana.com
CHAINMERGE_RPC_URL_COSMOS=https://rest.cosmos.directory/cosmoshub
CHAINMERGE_RPC_URL_APTOS=https://api.mainnet.aptoslabs.com/v1
CHAINMERGE_RPC_URL_SUI=https://fullnode.mainnet.sui.io:443
CHAINMERGE_RPC_URL_POLKADOT=https://polkadot.api.subscan.io
CHAINMERGE_RPC_URL_BITCOIN=https://blockstream.info/api
CHAINMERGE_RPC_URL_STARKNET=https://rpc.starknet.lava.build

# Needed for polkadot decode via Subscan
# POLKADOT_SUBSCAN_API_KEY=your_subscan_api_key
